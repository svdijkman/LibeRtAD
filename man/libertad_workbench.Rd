\name{libertad_workbench}
\alias{libertad_workbench}
\title{LibeRtAD benchmark workbench widget}
\usage{
libertad_workbench(
  payload,
  input_id = "libertad_workbench",
  width = NULL,
  height = "100vh",
  elementId = NULL
)
}
\arguments{
\item{payload}{Workbench payload generated by \code{libertad_gui()}.}
\item{input_id}{Shiny event prefix.}
\item{width, height}{Widget dimensions.}
\item{elementId}{Optional widget element id.}
}
\value{An htmlwidget for the LibeRtAD benchmark laboratory.}
\description{Create the React/htmlwidgets LibeRtAD benchmark workbench.}
